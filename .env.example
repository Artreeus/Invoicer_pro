# MongoDB connection (used by the Node API server in /server)
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=Cluster0"

# Port the API server listens on
PORT=4000

# Secret used to sign JWT auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Frontend -> API base URL. Leave empty in dev (Vite proxies /api to the server).
# Set to the deployed server URL in production, e.g. https://api.example.com
VITE_API_URL=

# Cloudinary (server signs image uploads; the API secret never reaches the browser)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google AdSense publisher id, e.g. ca-pub-1234567890123456 (leave empty until approved)
VITE_ADSENSE_CLIENT=
# Default AdSense ad-unit slot id (numeric)
VITE_ADSENSE_SLOT=
# Public site URL for sitemap.xml / robots.txt / canonical tags
VITE_SITE_URL=https://your-domain.com
# Public contact email (Contact page + Privacy Policy)
VITE_CONTACT_EMAIL=you@example.com
