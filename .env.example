# MongoDB connection (used by the Node API server in /server)
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=Cluster0"

# Port the API server listens on
PORT=4000

# Frontend -> API base URL. Leave empty in dev (Vite proxies /api to the server).
# Set to the deployed server URL in production, e.g. https://api.example.com
VITE_API_URL=
